# ============================================================
# Precision Receipt — Production Environment Variables
# Copy to /opt/digitalslips/.env.prod on the GCP VM
# ============================================================

# ── Release (managed automatically by deploy/rollback scripts) ──
RELEASE_TAG=latest
REGISTRY=us-central1-docker.pkg.dev/YOUR_PROJECT_ID/digitalslips

# ── Database ──
DB_PASSWORD=GENERATE_STRONG_PASSWORD

# ── Security Keys (generate each with: openssl rand -hex 32) ──
JWT_SECRET=GENERATE_WITH_OPENSSL
ENCRYPTION_KEY=GENERATE_WITH_OPENSSL
SESSION_SECRET=GENERATE_WITH_OPENSSL

# ── Twilio (WhatsApp & SMS) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+14155238886
TWILIO_SMS_PHONE_NUMBER=
SMS_ENABLED=false
SMS_PROVIDER=twilio

# ── External URL (used for webhook URLs, receipt verification links) ──
PUBLIC_URL=https://your-domain.com

# ── OpenAI (cheque OCR via Vision) ──
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o
