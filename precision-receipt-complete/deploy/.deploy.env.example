# ============================================================
# Deploy Script Configuration
# Copy to deploy/.deploy.env and fill in values
# Used by deploy.sh and rollback.sh on your LOCAL machine
# ============================================================

GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_VM_NAME=digitalslips-vm
GCP_VM_ZONE=us-central1-a
ARTIFACT_REPO=digitalslips
REMOTE_APP_DIR=/opt/digitalslips
